# =============================================================================
# Application Configuration
# =============================================================================
APP_NAME=deliveru
PRODUCTION=false

# =============================================================================
# Port Configuration
# =============================================================================
BACKEND_PORT=8504
FRONTEND_PORT=8503

# =============================================================================
# Database Configuration
# =============================================================================
POSTGRES_USER=root
POSTGRES_PASSWORD=password
POSTGRES_DB=app
DATABASE_URL=postgresql+asyncpg://root:password@pgbouncer:6432/deliveru

# =============================================================================
# Redis Configuration
# =============================================================================
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=redis_secret
REDIS_URL=redis://:redis_secret@redis:6379

# =============================================================================
# MinIO Configuration
# =============================================================================
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=minioadmin
MINIO_ENDPOINT=minio:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_BUCKET_NAME=uploads
MINIO_SECURE=false

# =============================================================================
# Authentication & Security
# =============================================================================
JWT_SECRET_KEY=your-secret-key-change-in-production
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=120

# =============================================================================
# API Documentation
# =============================================================================
API_USER=admin
API_PASSWORD=password

# =============================================================================
# Application URLs
# =============================================================================
FRONTEND_URL=http://localhost:8503
BACKEND_URL=http://localhost:8504
VITE_API_URL=http://localhost:8504

# =============================================================================
# File Processing
# =============================================================================
MAX_FILE_SIZE=52428800
